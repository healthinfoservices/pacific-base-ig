       ] ;
       fhir:name [ fhir:v "Pacific Practitioner Example – Samoa" ] ;
       fhir:description [ fhir:v "Registered practitioner with official registration name and usual community name including clan affiliation." ] ;
       fhir:example [
         a fhir:Canonical ;
         fhir:v "https://healthinfoservices.net/pacific-base-ig/StructureDefinition/pacific-practitioner"^^xsd:anyURI ;
