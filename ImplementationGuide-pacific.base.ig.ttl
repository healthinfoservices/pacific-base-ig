         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://healthinfoservices.net/pacific-base-ig/StructureDefinition/pacific-practitioner> ;
         fhir:reference [ fhir:v "StructureDefinition/pacific-practitioner" ]
       ] ;
       fhir:name [ fhir:v "Pacific Practitioner" ] ;
       fhir:description [ fhir:v "Practitioner profile for Pacific jurisdictions supporting culturally appropriate naming \nwhile maintaining regulatory and medico-legal identity requirements.\n\nRequires at least one official name (registered/licensed name).\nSupports usual name for culturally recognised or commonly used name.\nSupports clan affiliation as an optional extension." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Practitioner"
         ]
       ] ) ;
       fhir:reference [
