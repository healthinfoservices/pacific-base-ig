       ] ;
       fhir:name [ fhir:v "Pacific Practitioner Role" ] ;
       fhir:description [ fhir:v "Defines the functional, organisational, and regulatory role of a Pacific Practitioner.\n\nSupports multiple roles per practitioner (e.g., GP, hospital consultant, outreach clinician).\nIntended for use in Pacific regional health systems and future HIE environments." ] ;
