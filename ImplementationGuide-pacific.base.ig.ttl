         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://healthinfoservices.net/pacific-base-ig/StructureDefinition/pacific-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/pacific-observation" ]
       ] ;
       fhir:name [ fhir:v "Pacific Observation" ] ;
       fhir:description [ fhir:v "Profile of Observation as defined for South Pacific." ] ;
       fhir:example [
