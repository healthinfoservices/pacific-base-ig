         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://healthinfoservices.net/pacific-base-ig/StructureDefinition/pacific-humanname> ;
         fhir:reference [ fhir:v "StructureDefinition/pacific-humanname" ]
       ] ;
       fhir:name [ fhir:v "Pacific HumanName" ] ;
       fhir:description [ fhir:v "A HumanName profile designed for South Pacific jurisdictions.\n\nThis profile supports:\n- Absence of family names\n- Patronymic structures\n- Multiple given names\n- Customary and ceremonial naming\n- Distinction between 'usual' (social) and 'official' (legal) names\n\nAt least one HumanName instance must exist on Patient.\nSystems SHALL NOT require both usual and official names." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
