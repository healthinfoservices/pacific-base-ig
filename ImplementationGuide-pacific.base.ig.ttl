           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://healthinfoservices.net/pacific-base-ig/StructureDefinition/pacific-patient> ;
         fhir:reference [ fhir:v "StructureDefinition/pacific-patient" ]
       ] ;
       fhir:name [ fhir:v "Pacific Patient" ] ;
       fhir:description [ fhir:v "Base Patient profile for South Pacific jurisdictions.\n\nIntegrates:\n- PacificHumanName\n- Patient-level clan affiliation\n- Guidance for usual vs official name use" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
