           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Organization"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://healthinfoservices.net/pacific-base-ig/Organization/PacificHospitalExample> ;
         fhir:reference [ fhir:v "Organization/PacificHospitalExample" ]
       ] ;
       fhir:name [ fhir:v "Pacific Hospital Example – Fiji Divisional Hospital" ] ;
       fhir:description [ fhir:v "Example Pacific hospital organization in Fiji.\nIncludes organizational identifier, contact information, and address." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v true
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
