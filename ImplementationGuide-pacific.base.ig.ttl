           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://healthinfoservices.net/pacific-base-ig/StructureDefinition/pacific-condition> ;
         fhir:reference [ fhir:v "StructureDefinition/pacific-condition" ]
       ] ;
       fhir:name [ fhir:v "Pacific Condition" ] ;
       fhir:description [ fhir:v "Profile of Condition as defined for South Pacific." ] ;
